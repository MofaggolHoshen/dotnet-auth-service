{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=AuthServiceDb;Trusted_Connection=true;Encrypt=false"
  },
  "JwtSettings": {
    "SecretKey": "your-secret-key-must-be-at-least-32-characters-long-12345",
    "Issuer": "AuthService",
    "Audience": "AuthServiceClients",
    "AccessTokenExpirationMinutes": 15
  },
  "EmailSettings": {
    "Provider": "stub"
  },
  "SmtpSettings": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "SenderEmail": "your-email@gmail.com",
    "SenderName": "Auth Service",
    "Username": "your-email@gmail.com",
    "Password": "your-app-password"
  },
  "SendGridSettings": {
    "ApiKey": "your-sendgrid-api-key",
    "SenderEmail": "noreply@example.com",
    "SenderName": "Auth Service"
  },
  "AppUrl": "https://localhost:7000"
}
